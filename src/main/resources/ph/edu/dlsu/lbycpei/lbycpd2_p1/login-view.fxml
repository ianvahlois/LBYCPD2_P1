<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="12" alignment="CENTER"
      xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="ph.edu.dlsu.lbycpei.lbycpd2_p1.controller.LoginController">

    <padding><Insets top="16" right="20" bottom="16" left="20"/></padding>

    <Label text="Payroll System Login" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

    <VBox spacing="8" fillWidth="true">
        <HBox spacing="8" alignment="CENTER_LEFT">
            <Label text="Username:" minWidth="80"/>
            <TextField fx:id="usernameField" promptText="admin" prefWidth="220"/>
        </HBox>
        <HBox spacing="8" alignment="CENTER_LEFT">
            <Label text="Password:" minWidth="80"/>
            <PasswordField fx:id="passwordField" promptText="••••••••" prefWidth="220"/>
        </HBox>
    </VBox>

    <Button fx:id="loginButton"
            text="Login"
            defaultButton="true"
            onAction="#handleLogin"
            prefWidth="120"/>

    <Label text="Hint: default account is admin / admin123"
           style="-fx-font-size: 11px; -fx-text-fill: #666666;"/>

</VBox>

