<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="ph.edu.dlsu.lbycpei.lbycpd2_p1.controller.LoginController"
      alignment="CENTER"
      styleClass="login-panel"
      stylesheets="@app.css">

    <padding><Insets top="24" right="28" bottom="24" left="28"/></padding>

    <Label text="Payroll System Login" styleClass="login-title"/>

    <VBox spacing="10" style=" -fx-padding: 16 0 8 0;">
        <HBox spacing="10" alignment="CENTER_LEFT">
            <Label text="Username:" minWidth="80"/>
            <TextField fx:id="usernameField" promptText="Username" prefWidth="220"/>
        </HBox>
        <HBox spacing="10" alignment="CENTER_LEFT">
            <Label text="Password:" minWidth="80"/>
            <PasswordField fx:id="passwordField" promptText="••••••••" prefWidth="220"/>
        </HBox>
    </VBox>

    <Button fx:id="loginButton"
            text="Login"
            defaultButton="true"
            onAction="#handleLogin"
            prefWidth="140"
            styleClass="btn-primary"/>

    <Label text="Sign in to access payroll."
           styleClass="login-hint"
           style="-fx-padding: 8 0 0 0;"/>

</VBox>

