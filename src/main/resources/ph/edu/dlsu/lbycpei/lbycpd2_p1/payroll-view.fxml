<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="ph.edu.dlsu.lbycpei.lbycpd2_p1.controller.PayrollController"
            stylesheets="@app.css">

    <top>
        <VBox spacing="8" styleClass="toolbar-panel">
            <padding><Insets top="10" right="12" bottom="8" left="12"/></padding>

            <HBox spacing="8" alignment="CENTER_LEFT">
                <Button text="Load CSV" onAction="#loadCSV" styleClass="btn-primary"/>
                <Button text="Add Employee" onAction="#addEmployee" styleClass="btn-action"/>
                <Button text="Edit Selected" onAction="#editSelectedEmployee"/>
                <Button text="Add Paid Leave" onAction="#addPaidLeave"/>
                <Button text="Remove Paid Leave" onAction="#removePaidLeave"/>
                <Button text="Generate Receipts" onAction="#generateReceipts"/>
                <Button text="Export" onAction="#exportPayroll"/>
            </HBox>

            <HBox spacing="8" alignment="CENTER_LEFT">
                <Label text="Company name (for receipts):"/>
                <TextField fx:id="companyNameField" promptText="Company Name" prefWidth="220"/>
                <Label text="Default hourly rate (attendance report):"/>
                <TextField fx:id="defaultRateField" promptText="e.g. 100" prefWidth="80"/>
            </HBox>

            <HBox spacing="8" alignment="CENTER_LEFT">
                <Label text="Search:"/>
                <TextField fx:id="searchField" promptText="Search by name, ID, client" prefWidth="220"/>
                <Label text="Department:"/>
                <TextField fx:id="departmentFilterField" promptText="Filter by department" prefWidth="160"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <TableView fx:id="table" minHeight="240">
            <columns>
                <TableColumn text="Employee ID" fx:id="idCol" minWidth="90" prefWidth="100"/>
                <TableColumn text="Name" fx:id="nameCol" minWidth="140" prefWidth="180"/>
                <TableColumn text="Client / Dept." fx:id="clientCol" minWidth="120" prefWidth="140"/>
                <TableColumn text="Eff. Hours" fx:id="hoursCol" minWidth="80" prefWidth="90"/>
                <TableColumn text="Rate" fx:id="rateCol" minWidth="70" prefWidth="80"/>
                <TableColumn text="Gross Pay" fx:id="grossCol" minWidth="90" prefWidth="100"/>
                <TableColumn text="SSS" fx:id="sssCol" minWidth="70" prefWidth="80"/>
                <TableColumn text="PhilHealth" fx:id="philhealthCol" minWidth="85" prefWidth="95"/>
                <TableColumn text="Pag-IBIG" fx:id="pagibigCol" minWidth="75" prefWidth="85"/>
                <TableColumn text="Tax" fx:id="taxCol" minWidth="70" prefWidth="80"/>
                <TableColumn text="Net Pay" fx:id="netCol" minWidth="90" prefWidth="100"/>
            </columns>
        </TableView>
    </center>

    <bottom>
        <VBox spacing="6" styleClass="dashboard-panel">
            <padding><Insets top="10" right="12" bottom="12" left="12"/></padding>
            <Label fx:id="summaryLabel" text="No payroll data loaded." wrapText="true" maxWidth="Infinity"/>

            <HBox spacing="20" alignment="CENTER_LEFT">
                <Label text="Total Employees:"/>
                <Label fx:id="totalEmployeesLabel" text="0" styleClass="dashboard-value"/>
                <Label text="Total Gross:"/>
                <Label fx:id="totalGrossLabel" text="Php 0.00" styleClass="dashboard-value"/>
                <Label text="Total Deductions:"/>
                <Label fx:id="totalDeductionsLabel" text="Php 0.00" styleClass="dashboard-value"/>
                <Label text="Total Net:"/>
                <Label fx:id="totalNetLabel" text="Php 0.00" styleClass="dashboard-value"/>
            </HBox>
        </VBox>
    </bottom>
</BorderPane>

